# ── Required ────────────────────────────────────────────────────────────────
# Shared secret for HMAC token verification (same value as claude-code-web)
NEXTAUTH_SECRET=your-secret-here

# ── API Key Authentication ──────────────────────────────────────────────────
# Comma-separated list of API keys
# Simple key:     API_KEYS=sk-my-secret-key
# Prefixed key:   API_KEYS=myapp:sk-key1,bot:sk-key2
#   → userId is derived from prefix ("myapp", "bot")
#   → Without prefix, userId defaults to "api"
# API_KEYS=

# ── Server settings ──────────────────────────────────────────────────────────
# Claude model (default: claude-sonnet-4-6)
# CLAUDE_MODEL=claude-sonnet-4-6

# Server port (default: 8080)
# PORT=8080

# Worker pool size (default: 1)
# POOL_SIZE=2
